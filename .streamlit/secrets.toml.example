# ============================================================
# Streamlit Secrets — пример (для Streamlit Cloud)
# ============================================================
# Этот файл — ШАБЛОН. Реальный secrets.toml в .gitignore.
#
# Для Streamlit Cloud: содержимое этого файла вставляется в
# Settings → Secrets через UI (НЕ через файл).
#
# Для локального теста: скопируй этот файл в .streamlit/secrets.toml
# и заполни своими значениями.
# ============================================================

# --- Postgres (Supabase или другой managed) ---
PG_HOST = "db.xxxxxxxxxxxxxxxxxxxx.supabase.co"
PG_PORT = "5432"
PG_DB   = "postgres"
PG_USER = "postgres"
PG_PASSWORD = "вставь_пароль_из_supabase"

# Дубли (в коде встречается обе формы названий — POSTGRES_* и PG_*)
POSTGRES_HOST = "db.xxxxxxxxxxxxxxxxxxxx.supabase.co"
POSTGRES_PORT = "5432"
POSTGRES_DB   = "postgres"
POSTGRES_USER = "postgres"
POSTGRES_PASSWORD = "вставь_пароль_из_supabase"

# --- LLM-провайдер ---
# Варианты: "ollama" (только для локалки), "groq", "anthropic", "openai"
LLM_PROVIDER = "groq"

# Groq (бесплатно, https://console.groq.com/keys)
GROQ_API_KEY = "gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Модель для генерации SQL.
# Free-tier TPM (tokens per minute) Groq:
#   meta-llama/llama-4-scout-17b-16e-instruct → 30K  ⭐ дефолт
#   llama-3.3-70b-versatile                   → 12K  (мало под наш промпт)
#   openai/gpt-oss-120b                       →  8K  (флагман, но медленнее)
#   qwen/qwen3-32b                            →  6K  (preview)
GROQ_MODEL          = "meta-llama/llama-4-scout-17b-16e-instruct"

# Модель для резюме под таблицей.
# По умолчанию та же Llama-4-Scout — даёт самые точные структурированные
# ответы. Если упрёшься в 429 (TPM-лимит) на частых запросах — переключи на
# "openai/gpt-oss-20b" (отдельный 8K-бакет, 1000 t/s).
GROQ_MODEL_SUMMARY  = "meta-llama/llama-4-scout-17b-16e-instruct"

# Anthropic — раскомментируй если переключаешься
# ANTHROPIC_API_KEY = "sk-ant-..."
# ANTHROPIC_MODEL   = "claude-haiku-4-5"

# OpenAI — раскомментируй если переключаешься
# OPENAI_API_KEY = "sk-..."
# OPENAI_MODEL   = "gpt-4o-mini"

# --- Если временно остаёшься на Ollama (туннель к локалке через ngrok) ---
# OLLAMA_URL  = "https://xxxx.ngrok-free.app/api/generate"
# OLLAMA_MODEL = "glm4:9b"
# OLLAMA_NUM_CTX = "12288"

# --- Прочее ---
TOP_K = "6"
VECTOR_CANDIDATES = "50"
