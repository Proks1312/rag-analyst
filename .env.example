# ============================================================
# RAG Analyst — пример конфигурации
# ============================================================
# Скопируй этот файл в .env и заполни своими значениями.
# Файл .env НЕ должен попасть в git (он в .gitignore).
# ============================================================

# Postgres (поднимается через docker-compose.yml)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_DB=rag_db
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=CHANGE_ME_to_strong_password

# Дубли для скриптов, которые ожидают PG_* префикс.
# Значения должны совпадать с POSTGRES_*.
PG_HOST=127.0.0.1
PG_PORT=5433
PG_DB=rag_db
PG_USER=rag_user
PG_PASSWORD=CHANGE_ME_to_strong_password

# ============================================================
# Ollama
# ============================================================
OLLAMA_URL=http://localhost:11434/api/generate

# Базовая модель (используется в RAG если алиас "default")
OLLAMA_MODEL=qwen3:14b

# SQL и Summary — рекомендуется glm4:9b (быстро + точно)
OLLAMA_MODEL_SQL=glm4:9b
OLLAMA_MODEL_SUMMARY=glm4:9b

# Контекст окно Ollama. Меньше — быстрее, но риск обрезки промпта.
OLLAMA_NUM_CTX=12288

# Использовать /api/chat вместо /api/generate. Включай для qwen3
# (он лучше следует system role'у). При 404 авто-fallback на /api/generate.
# OLLAMA_USE_CHAT=true

# ============================================================
# Embedding и RAG (для будущей доработки документного маршрута)
# ============================================================
EMBEDDING_MODEL=BAAI/bge-m3
TOP_K=6
VECTOR_CANDIDATES=50

# Cross-encoder rerank (опционально, +3-7 сек на CPU)
# USE_CROSS_ENCODER=true
# CROSS_ENCODER_MODEL=BAAI/bge-reranker-v2-m3
# CROSS_ENCODER_MAX_LEN=1024

# Антикластер: макс N чанков одной таблицы/секции в top-K
# DIVERSIFY_MAX_PER_GROUP=2

# ============================================================
# HuggingFace (для скачки моделей)
# ============================================================
# Получи токен на https://huggingface.co/settings/tokens (Read)
HF_TOKEN=hf_CHANGE_ME
HF_HUB_ENABLE_HF_TRANSFER=1
